{
  "telemetry.enableTelemetry": false,
  "editor.minimap.enabled": false,
  "editor.fontFamily": "'JetBrains Mono', 'Cascadia Code', 'Fira Code Regular', 'Terminus (TTF) for Windows', Consolas, 'Courier New', monospace",
//   "editor.fontFamily": "'JetBrains Mono', 'Cascadia Code', 'Fira Code Regular', 'Terminus (TTF) for Windows', Consolas, 'Courier New', monospace",
  "editor.fontSize": 15,
  "editor.fontLigatures": true,
  "editor.formatOnSave": true,
  "editor.formatOnPaste": true,
  "editor.autoClosingQuotes": "never",
  "editor.autoClosingBrackets": "never",
  "editor.autoSurround": "never",
  // "terminal.integrated.shell.windows": "C:\\WINDOWS\\System32\\wsl.exe",
  // "terminal.integrated.shell.windows": "C:\\Windows\\System32\\bash.exe",
  // "terminal.integrated.shell.windows": "C:\\WINDOWS\\Sysnative\\WindowsPowerShell\\v1.0\\powershell.exe",
  "terminal.integrated.shell.windows": "C:\\Program Files\\PowerShell\\7-preview\\pwsh.exe",
  "terminal.integrated.scrollback": 10000,
//   "terminal.integrated.fontFamily": "Fira Code Medium",
  "terminal.integrated.fontFamily": "CaskaydiaCove NF",
  "terminal.integrated.fontSize": 14,
  "explorer.confirmDelete": false,
  "explorer.confirmDragAndDrop": false,
  //  "[nim]": {},
  "files.exclude": {
    "**/.git": true,
    "**/.svn": true,
    "**/.hg": true,
    "**/CVS": true,
    "**/.DS_Store": true,
    "**/nimcache": true,
    "**/__pycache__": true
  },
  "window.zoomLevel": 0,
  "files.eol": "\n",
  "workbench.settings.editor": "json",
  "workbench.colorCustomizations": {
    "statusBar.background": "#005f5f",
    "statusBar.noFolderBackground": "#005f5f",
    "statusBar.debuggingBackground": "#005f5f"
  },
  "javascript.updateImportsOnFileMove.enabled": "always",
  "go.formatTool": "goimports",
  "python.venvPath": "C:/Users/durdn/dev",
  "python.pythonPath": "C:\\Users\\durdn\\dev\\env\\generic\\Scripts\\python.exe",
  "python.formatting.provider": "autopep8",
  "python.linting.enabled": false,
  "prettier.singleQuote": true,
  // vim configuration
  "vim.leader": ",",
  "vim.useSystemClipboard": true,
  "vim.statusBarColorControl": false,
  "vim.useCtrlKeys": true,
  "vim.normalModeKeyBindingsNonRecursive": [
    {
      "before": ["leader", "d"],
      "after": [],
      "commands": [
        {
          "command": "workbench.action.toggleSidebarVisibility",
          "args": []
        }
      ]
    }
  ],
  "vim.insertModeKeyBindings": [
    {
      "before": ["j", "j"],
      "after": ["<Esc>"]
    },
    {
        "before": ["j", "k"],
        "after": ["<Esc>"]
    }
  ],
  "workbench.editor.enablePreview": false,
  "workbench.editor.limit.enabled": true,
  "workbench.editor.limit.value": 8,
  "html.format.enable": false,
  "html.format.wrapLineLength": 0,
  "[html]": {
    "editor.formatOnSave": false,
    "editor.formatOnPaste": false
  },
  "markdown.preview.fontSize": 16,
  "files.autoSave": "afterDelay",
  "go.lintTool": "revive",
  "editor.multiCursorModifier": "alt",
  "terminal.integrated.rendererType": "experimentalWebgl",
  "[json]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "go.useLanguageServer": true,
  "[go]": {
    "editor.formatOnSave": true,
    "editor.codeActionsOnSave": {
      "source.organizeImports": true
    },
    // Optional: Disable snippets, as they conflict with completion ranking.
    "editor.snippetSuggestions": "none"
  },
  "[go.mod]": {
    "editor.formatOnSave": true,
    "editor.codeActionsOnSave": {
      "source.organizeImports": true
    }
  },
  "sshfs.configs": [
    {
      "name": "dash.local",
      "host": "dash.local",
      "username": "pi",
      "password": true,
      "root": "/home",
      "putty": "dash.local"
    }
  ],
"vetur.format.options.tabSize": 4,
"editor.detectIndentation": false,
"python.showStartPage": false,
"workbench.editorAssociations": {
    "*.ipynb": "jupyter.notebook.ipynb"
},
"security.workspace.trust.untrustedFiles": "open"
  // "gopls": {
  //   // Add parameter placeholders when completing a function.
  //   "usePlaceholders": true,

  //   // If true, enable additional analyses with staticcheck.
  //   // Warning: This will significantly increase memory usage.
  //   "staticcheck": false
  // }
}
